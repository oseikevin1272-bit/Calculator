{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug advanced.exe (gdb)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/kevin/advanced.exe",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}/kevin",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "C:/mingw64/bin/gdb.exe",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ],
      "preLaunchTask": "build advanced.exe"
    }
  ]
}
